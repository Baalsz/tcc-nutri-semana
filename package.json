{
  "name": "tcce-planejamento-alimentar-ia",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -n FRONTEND,BACKEND -c cyan,magenta \"npm:dev -w frontend\" \"npm:dev -w backend\"",
    "build": "npm run build -w frontend",
    "start": "npm run start -w backend",
    "db:push": "npm run db:push -w backend",
    "db:seed": "npm run db:seed -w backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "prisma": "^7.8.0"
  }
}
